{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socialism-destroyer.dev/schemas/v2/topic.schema.json",
  "title": "TopicDocument",
  "type": "object",
  "required": ["schemaVersion", "kbVersion", "updatedAt", "topics"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 2 },
    "kbVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "contentHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "topics": {
      "type": "array",
      "items": { "$ref": "#/$defs/TopicNode" }
    }
  },
  "$defs": {
    "TopicNode": {
      "type": "object",
      "required": ["id", "title", "order"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "parentId": { "type": ["string", "null"] },
        "path": { "type": "string", "pattern": "^(/[a-z0-9-]+)+$" },
        "depth": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "integer", "minimum": 0 },
        "schemaVersion": { "type": "integer" },
        "kbVersion": { "type": "string" },
        "revision": { "type": "integer", "minimum": 1 },
        "contentHash": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}