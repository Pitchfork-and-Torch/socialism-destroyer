/*
  ! Access-Control-Allow-Origin
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' 'unsafe-eval' blob: https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data: blob: https://fonts.gstatic.com; connect-src 'self' blob: https://fonts.gstatic.com https://www.gstatic.com https://destroyer.jonbailey.xyz; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

/index.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1

/
  Cache-Control: public, max-age=0, must-revalidate

/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8
  Access-Control-Allow-Origin: *
  X-Robots-Tag: index, follow

/manifest.json
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json; charset=utf-8

/favicon.png
  Cache-Control: public, max-age=604800, immutable

/twitter-card.png
  Cache-Control: public, max-age=604800, immutable
  X-Robots-Tag: index, follow, max-image-preview:large

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/flutter_bootstrap.js
  Cache-Control: public, max-age=0, must-revalidate

/flutter.js
  Cache-Control: public, max-age=0, must-revalidate

/flutter_service_worker.js
  Cache-Control: public, max-age=0, must-revalidate

/main.dart.js
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=3600, must-revalidate

/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: same-site

/knowledge/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300, must-revalidate

/knowledge/*.json
  Access-Control-Allow-Origin: *
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=300, must-revalidate

/knowledge/*.txt
  Access-Control-Allow-Origin: *
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/7577922ed4d3ec3df303933b78cbd0ee.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/version.json
  Cache-Control: public, max-age=0, must-revalidate
